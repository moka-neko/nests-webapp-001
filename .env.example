# Database
DATABASE_URL=file:./dev.db

# JWT (管理者ログイン)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN_SECONDS=28800

# 初期管理者（初回起動時に自動作成）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=管理者

# 応募受付 API キー（設定時は POST 応募 API に x-api-key ヘッダーが必須）
APPLICATION_API_KEY=

# TimeRex Webhook シークレット（設定時は x-webhook-secret ヘッダーが必須）
TIMEREX_WEBHOOK_SECRET=

# CORS（カンマ区切り。未設定時は全オリジン許可）
CORS_ORIGINS=

# LINE Login (OAuth)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:3000/api/v1/auth/line/callback

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_GROUP_ID=

# Mail (SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=塾応募管理 <noreply@example.com>

# Server
PORT=3000
