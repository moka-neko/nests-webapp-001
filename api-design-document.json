{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": { "200": { "description": "" } },
        "tags": ["App"]
      }
    },
    "/api/v1/teachers/applications": {
      "post": {
        "description": "先生の新規応募を受け付け、データベースへ保存する。運営グループへのLINE通知と、応募者への確認メール送信を行う。",
        "operationId": "TeachersController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTeacherApplicationDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "応募の受け付けに成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TeacherApplicationResponseDto"
                }
              }
            }
          },
          "400": { "description": "リクエストパラメータが不正" }
        },
        "summary": "先生の新規応募",
        "tags": ["teachers"]
      },
      "get": {
        "description": "先生の応募データ一覧を取得する。",
        "operationId": "TeachersController_findAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "一覧取得に成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TeacherApplicationResponseDto"
                  }
                }
              }
            }
          }
        },
        "summary": "先生の応募データ一覧取得",
        "tags": ["teachers"]
      }
    },
    "/api/v1/teachers/applications/{id}/status": {
      "patch": {
        "description": "先生の選考ステータス（採用・不採用・面接実施）を更新し、結果に応じたメール送信およびLINE個別通知を行う。",
        "operationId": "TeachersController_updateStatus",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "先生応募ID（UUID）",
            "schema": { "example": "a1b2c3d4-...", "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTeacherStatusDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ステータス更新に成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TeacherApplicationResponseDto"
                }
              }
            }
          },
          "404": { "description": "指定したIDの応募データが存在しない" }
        },
        "summary": "先生の選考ステータス更新",
        "tags": ["teachers"]
      }
    },
    "/api/v1/teachers/applications/{id}": {
      "get": {
        "description": "指定 ID の先生応募データを取得する。",
        "operationId": "TeachersController_findOne",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "先生応募ID（UUID）",
            "schema": { "example": "a1b2c3d4-...", "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "詳細取得に成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TeacherApplicationResponseDto"
                }
              }
            }
          },
          "404": { "description": "指定したIDの応募データが存在しない" }
        },
        "summary": "先生の応募データ詳細取得",
        "tags": ["teachers"]
      },
      "put": {
        "description": "先生の基本情報（名前、年齢、勤務場所、履歴書URLなど）を修正する。",
        "operationId": "TeachersController_update",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "先生応募ID（UUID）",
            "schema": { "example": "a1b2c3d4-...", "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTeacherApplicationDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新に成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TeacherApplicationResponseDto"
                }
              }
            }
          },
          "404": { "description": "指定したIDの応募データが存在しない" }
        },
        "summary": "先生の基本情報更新",
        "tags": ["teachers"]
      },
      "delete": {
        "description": "指定した先生の応募データを削除する。",
        "operationId": "TeachersController_remove",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "先生応募ID（UUID）",
            "schema": { "example": "a1b2c3d4-...", "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "削除に成功" },
          "404": { "description": "指定したIDの応募データが存在しない" }
        },
        "summary": "先生の応募データ削除",
        "tags": ["teachers"]
      }
    },
    "/api/v1/students/applications": {
      "post": {
        "description": "生徒の新規応募を受け付け、データベースへ保存する。運営グループへの通知等を行う。",
        "operationId": "StudentsController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateStudentApplicationDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "応募の受け付けに成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StudentApplicationResponseDto"
                }
              }
            }
          },
          "400": { "description": "リクエストパラメータが不正" }
        },
        "summary": "生徒の新規応募",
        "tags": ["students"]
      },
      "get": {
        "description": "生徒の応募データ一覧を取得する。",
        "operationId": "StudentsController_findAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "一覧取得に成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StudentApplicationResponseDto"
                  }
                }
              }
            }
          }
        },
        "summary": "生徒の応募データ一覧取得",
        "tags": ["students"]
      }
    },
    "/api/v1/students/applications/{id}": {
      "get": {
        "description": "指定 ID の生徒応募データを取得する。",
        "operationId": "StudentsController_findOne",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "生徒応募ID（UUID）",
            "schema": { "example": "b2c3d4e5-...", "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "詳細取得に成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StudentApplicationResponseDto"
                }
              }
            }
          },
          "404": { "description": "指定したIDの応募データが存在しない" }
        },
        "summary": "生徒の応募データ詳細取得",
        "tags": ["students"]
      },
      "put": {
        "description": "生徒の基本情報（名前、電話番号、国籍など）を修正する。",
        "operationId": "StudentsController_update",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "生徒応募ID（UUID）",
            "schema": { "example": "b2c3d4e5-...", "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateStudentApplicationDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新に成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StudentApplicationResponseDto"
                }
              }
            }
          },
          "404": { "description": "指定したIDの応募データが存在しない" }
        },
        "summary": "生徒の基本情報更新",
